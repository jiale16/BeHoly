<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 前台服务：常驻通知（离线监护 + 合规拉起悔改页） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- 通知权限（Android 13 / API 33+ 需显式申请） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 查询前台应用（冷静期循环重锁时判断前台是否回到被封应用，需用户在系统中授予"使用情况访问权限"） -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <!-- 悬浮窗权限：作为后台启动 Activity 的已知豁免，提升悔改页在国产 ROM 上的可靠性 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- 重要：本项目严禁联网，绝不声明任何网络权限，无任何网络调用（遵循离线铁律） -->

    <application
        android:name=".BeHolyApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_notification"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_notification"
        android:supportsRtl="true"
        android:theme="@style/Theme.BeHoly">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 悔改提醒界面：检测到成人内容时弹出，打断当前浏览 -->
        <activity
            android:name=".ui.RepentanceActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:launchMode="singleTop"
            android:showWhenLocked="true"
            android:turnScreenOn="true" />

        <!-- 悔改反思表单：由 RepentanceActivity 启动，引导填写结构化反思（不新增任何权限） -->
        <activity
            android:name=".ui.RepentanceFormActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true" />

        <!-- 无障碍检测服务：遍历视图树文本做本地敏感词匹配（替代旧版截屏检测链） -->
        <service
            android:name=".service.BeHolyAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/beholy_accessibility_service" />
        </service>

        <!-- 前台常驻服务：常驻通知 + 合规拉起悔改页 + 冷静期循环重锁 -->
        <service
            android:name=".service.MonitoringService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="BeHoly 离线监护与悔改引导" />
        </service>

        <!-- Device Owner 接收器：adb 一次性 set-device-owner 激活后，方可执行封禁/锁屏/重启 -->
        <receiver
            android:name=".ui.BeHolyAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_policies" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
