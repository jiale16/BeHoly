<resources>
    <string name="app_name">BeHoly</string>
    <string name="accessibility_service_desc">BeHoly 通过读取屏幕上显示的文本与内容描述，在设备本地匹配敏感词库，于成人内容出现时引导悔改。所有处理均在本地完成，不会上传任何数据。</string>
