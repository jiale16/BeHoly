<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- 警示标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠ 警示"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#E74C3C"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

        <!-- 提示语 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="你正在浏览的内容不讨神喜悦。\n这罪正在偷走你与神的亲密。"
            android:textSize="16sp"
            android:textColor="#EEEEEE"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="28dp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="#E74C3C"
            android:layout_marginBottom="28dp" />

        <!-- 经文 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#16213E"
            android:padding="20dp"
            android:text="「你们要圣洁，因为我是圣洁的。」\n\n—— 彼得前书 1:16"
            android:textSize="17sp"
            android:textStyle="italic"
            android:textColor="#F0E68C"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#16213E"
            android:padding="20dp"
            android:text="「务要抵挡魔鬼，魔鬼就必离开你们逃跑了。你们亲近神，神就必亲近你们。」\n\n—— 雅各书 4:7-8"
            android:textSize="17sp"
            android:textStyle="italic"
            android:textColor="#F0E68C"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="28dp" />

        <!-- 呼召 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="现在就是悔改的时刻。\n转离这罪，归向你的神。\n祂的恩典够你用的，\n祂的慈爱永不断绝。"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="32dp" />

        <!-- 确认按钮：我愿意悔改 -->
        <Button
            android:id="@+id/btn_repent"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="我愿意悔改归向神"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#27AE60"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp" />

        <!-- 关闭按钮 -->
        <Button
            android:id="@+id/btn_close"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="返回 BeHoly"
            android:textSize="15sp"
            android:backgroundTint="#555555"
            android:textColor="#CCCCCC" />

    </LinearLayout>
</ScrollView>
