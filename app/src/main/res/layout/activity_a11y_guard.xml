<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F5FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/a11y_guard_title"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#C9971B"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

        <!-- 提问式劝诫 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/a11y_guard_body"
            android:textSize="16sp"
            android:textColor="#37474F"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="28dp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="#C9971B"
            android:layout_marginBottom="28dp" />

        <!-- 经文 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF3D6"
            android:padding="20dp"
            android:text="@string/a11y_guard_verse"
            android:textSize="17sp"
            android:textStyle="italic"
            android:textColor="#C9971B"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="32dp" />

        <!-- 主按钮：我再想想，回到 BeHoly -->
        <Button
            android:id="@+id/btn_a11y_guard_keep"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/a11y_guard_btn_keep"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#27AE60"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp" />

        <!-- 次按钮：我仍要关闭 -->
        <Button
            android:id="@+id/btn_a11y_guard_close"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/a11y_guard_btn_close"
            android:textSize="15sp"
            android:backgroundTint="#B0BEC5"
            android:textColor="#37474F" />

    </LinearLayout>
</ScrollView>
