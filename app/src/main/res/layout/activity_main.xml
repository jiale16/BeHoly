<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="16dp">

    <!-- 顶部标题区（连续点击 5 次显示停止按钮） -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_hint"
        android:textSize="12sp"
        android:textColor="#B0B0C0"
        android:layout_marginBottom="12dp" />

    <!-- 开启监控 -->
    <Button
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_start"
        android:backgroundTint="#27AE60"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp" />

    <!-- 步骤1：无障碍服务 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#16213E"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="步骤 1 · 开启无障碍服务"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_accessibility_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_accessibility_off"
            android:textSize="13sp"
            android:textColor="#E74C3C"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_open_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_open_accessibility"
            android:backgroundTint="#0E6391"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- 步骤2：Device Owner 配置 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#16213E"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="步骤 2 · 配置设备所有者（可选，解锁封禁/锁屏/重启）"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_device_owner_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_device_owner_off"
            android:textSize="13sp"
            android:textColor="#E67E22"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_configure_device_owner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_configure_device_owner"
            android:backgroundTint="#0E6391"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/do_uninstall_hint"
            android:textSize="11sp"
            android:textColor="#B0B0C0"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- 停止监控按钮（默认隐藏，连点标题 5 次后显示） -->
    <Button
        android:id="@+id/btn_stop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_stop"
        android:backgroundTint="#C0392B"
        android:textColor="#FFFFFF"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <!-- 查看记录 + 清空日志 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn_view_records"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="查看记录"
            android:backgroundTint="#34495E"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_clear_log"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="清空日志"
            android:backgroundTint="#34495E"
            android:textColor="#FFFFFF"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- 日志标签 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="━━━ 实时日志 ━━━"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="4dp" />

    <!-- 日志显示区：可滚动 -->
    <ScrollView
        android:id="@+id/log_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0F1626"
        android:padding="8dp">

        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="#A8E6A0"
            android:textIsSelectable="true"
            android:lineSpacingExtra="2dp"
            android:text="" />

    </ScrollView>
</LinearLayout>
